PORT=3001
SERVIENTREGA_AUTH_TOKEN=your_token_here
# Token secundario — se activa durante la transición de rotación de claves (cada 90 días)
# Dejar vacío cuando no haya rotación en curso
SERVIENTREGA_AUTH_TOKEN_SECONDARY=

# Callback hacia Bagisto - se dispara cuando una guia pasa a estado ENTREGADO
BAGISTO_CALLBACK_URL=http://goloba-prod.test/servientrega/delivery-confirmed
BAGISTO_CALLBACK_TOKEN=your_shared_secret_here

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=servientrega_tracking
